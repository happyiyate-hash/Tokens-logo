  "endpoints": {
    "account": {
      "balance": "?module=account&action=balance&address={address}&tag=latest",
      "tokenTransfers": "?module=account&action=tokentx&address={address}&sort=desc",
      "normalTransactions": "?module=account&action=txlist&address={address}&sort=desc",
      "internalTransactions": "?module=account&action=txlistinternal&address={address}&sort=desc",
      "multiBalance": "?module=account&action=balancemulti&address={addresses}&tag=latest"
    },
    "token": {
      "metadata": "?module=token&action=tokeninfo&contractaddress={contract}",
      "supply": "?module=stats&action=tokensupply&contractaddress={contract}",
      "holderList": "?module=token&action=tokenholderlist&contractaddress={contract}",
      "tokenPrice": "?module=stats&action=tokenprice&contractaddress={contract}"
    },
    "contract": {
      "abi": "?module=contract&action=getabi&address={contract}",
      "sourceCode": "?module=contract&action=getsourcecode&address={contract}",
      "creator": "?module=contract&action=getcontractcreation&contractaddresses={contract}"
    },
    "block": {
      "latestBlock": "?module=proxy&action=eth_blockNumber",
      "blockByNumber": "?module=block&action=getblockreward&blockno={blockNumber}"
    },
    "logs": {
      "eventLogs": "?module=logs&action=getLogs&fromBlock={fromBlock}&toBlock={toBlock}&address={contract}"
    },
    "gas": {
      "gasTracker": "?module=gastracker&action=gasoracle"
    },
    "proxy": {
      "ethCall": "?module=proxy&action=eth_call&to={contract}&data={data}",
      "sendRawTx": "?module=proxy&action=eth_sendRawTransaction&hex={signedTx}"
    },
    "stats": {
      "ethSupply": "?module=stats&action=ethsupply",
      "ethPrice": "?module=stats&action=ethprice"
    }
  }
}
